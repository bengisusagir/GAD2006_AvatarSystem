# Visual Studio user specific files
.vs/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/
Plugins/*/Binaries/

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for the editor
DerivedDataCache/

# Intermediate files generated by the engine
Intermediate/
Plugins/*/Intermediate/

# Saved files
Saved/

# macOS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# JetBrains Rider files
.idea/
*.sln.DotSettings.user

# Visual Studio Code files
.vscode/

# Ignore heavy, non-essential asset folders
Meshes/
Textures/
StarterContent/
Audio/

# default Unreal Engine template folders
LevelPrototyping/
Characters/
__ExternalActors__/
__ExternalObjects__/
Collections/
Developers/
Input/
